# Shared env variables used across apps/packages

# Core DB URL used by @acp/db tools (drizzle config / migrations)
DB_URL=postgres://postgres:postgres@localhost:5432/postgres

# Optional approvals store DB URL for example app gateway
# If omitted, example app uses in-memory approvals store
APPROVALS_DB_URL=postgres://postgres:postgres@localhost:5432/postgres

# Example approver webhook endpoint
APPROVER_WEBHOOK_URL=http://localhost:3300/approval-request

# Optional shared secret for custom HMAC webhook handlers (example docs/plugins)
APPROVER_SHARED_SECRET=dev-secret

# Optional runtime environment label
NODE_ENV=development

# Test-only path used by gateway tests
ACP_TEST_AUDIT_FILE=/tmp/acp-audit.log

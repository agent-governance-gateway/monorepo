# Shared env variables used across apps/packages

# Core DB URL used by @acp/db tools (drizzle config / migrations)
DB_URL=postgres://postgres:postgres@localhost:5432/postgres

# Control-plane store mode: memory (default) or postgres
STORE_TYPE=memory

# Store URL (used when STORE_TYPE=postgres)
STORE_URL=postgres://postgres:postgres@localhost:5432/postgres

# Generic DB URL alias (also accepted for postgres mode)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# Backward-compatible aliases (optional)
APPROVALS_STORE=memory
APPROVALS_DB_URL=postgres://postgres:postgres@localhost:5432/postgres

# Optional external approver webhook endpoint (not required for no-mocks flow)
APPROVER_WEBHOOK_URL=

# Optional shared secret for custom HMAC webhook handlers (example docs/plugins)
APPROVER_SHARED_SECRET=dev-secret

# Optional runtime environment label
NODE_ENV=development

# Gateway listen port for example app
GATEWAY_PORT=3100

# Test-only path used by gateway tests
ACP_TEST_AUDIT_FILE=/tmp/acp-audit.log

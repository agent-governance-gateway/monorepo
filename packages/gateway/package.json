{
  "name": "@acp/gateway",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@acp/approvals": "workspace:*",
    "@acp/audit": "workspace:*",
    "@acp/config": "workspace:*",
    "@acp/core": "workspace:*",
    "@acp/opa": "workspace:*",
    "@acp/telemetry": "workspace:*",
    "@acp/tools": "workspace:*",
    "@acp/utils": "workspace:*",
    "fast-glob": "^3.3.3",
    "fastify": "^5.2.1"
  }
}
